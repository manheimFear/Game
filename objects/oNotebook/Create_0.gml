// ══════════════════════════════════════════════════

// Кнопка ОТКРЫТИЯ стикера. Нажатие ТОЛЬКО открывает — закрыть нельзя
// повторным кликом. Закрывается: выбор разрешения или ESC.
// x,y — левый верхний угол; w,h — ширина / высота зоны.
resBtnOpen = {x: 710, y: 510, w: 266, h: 60}; // ← подбери координаты

// Три кнопки НА стикере (активны только когда showSticker == true).
// resIdx: 0=1280×720, 1=1536×864, 2=1920×1080
