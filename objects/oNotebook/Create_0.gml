resolutions = ["1280x720", "1536x864", "1920x1080"];
resWidths   = [1280, 1536, 1920];
resHeights  = [720,  864,  1080];
// Полноэкранные спрайты-оверлеи (1280×720), рисуются с (0,0) поверх фона.
// Индекс 0 → нет оверлея (-1). Индексы 1 и 2 → твои спрайты Window1536 / Window1920.
resOverlaySprites = [-1, Window1536, Window1920];
resIndex    = 0;     // текущее выбранное разрешение
showSticker = false; // true = жёлтый стикер открыт
// ↓ ЗАМЕНИ на имя спрайта жёлтого стикера (тот, что с тремя строками разрешений)
sStickerRes = sDropdownClosed;
// Позиция стикера на экране (левый верхний угол спрайта):
stickerX = 735; // ← подбери по скриншоту
stickerY = 320; // ← подбери по скриншоту
