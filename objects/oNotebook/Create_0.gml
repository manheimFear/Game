resBtnItems = [
    {x: 770, y: 390, w: 210, h: 45, resIdx: 2}, // 1920×1080 ← подбери
    {x: 770, y: 445, w: 210, h: 70, resIdx: 1}, // 1536×864  ← подбери
    {x: 790, y: 530, w: 200, h: 55, resIdx: 0}, // 1280×720  ← подбери
];

// true = рисовать красные рамки поверх кнопок (для настройки координат).
